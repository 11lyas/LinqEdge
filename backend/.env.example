# Azure AI Foundry / Azure OpenAI configuration
# Copy this file to `.env` and fill in the values from your Azure AI Foundry project.

# The endpoint of your Azure AI Foundry resource.
# Paste the resource endpoint; a full sample URL also works (it is normalized
# down to the host automatically). Examples that all work:
#   https://your-resource.services.ai.azure.com
#   https://your-resource.services.ai.azure.com/openai/v1/
#   https://your-resource.services.ai.azure.com/openai/v1/responses
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com

# The API key for the resource (found under "Keys and Endpoint" in the portal).
AZURE_OPENAI_API_KEY=your-api-key-here

# The name of your model deployment in Azure AI Foundry.
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini

# API version. Not used by the Foundry v1 API path; kept for reference/back-compat.
AZURE_OPENAI_API_VERSION=2024-10-21
